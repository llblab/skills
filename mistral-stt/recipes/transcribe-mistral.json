{
  "name": "transcribe-mistral",
  "description": "Transcribe an audio file through the Mistral STT skill.",
  "args": [
    "file:path",
    "lang:string=ru",
    "model:string=voxtral-mini-latest"
  ],
  "defaults": {
    "skill_dir": "~/.pi/agent/skills/mistral-stt"
  },
  "template": "{skill_dir}/scripts/transcribe.sh {file} {lang} {model}"
}
