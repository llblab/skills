#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
INSTALL_DIR="${HOME}/.local/bin"

. "$SCRIPT_DIR/_install-deps"

OS_TYPE="$(uname -s)"
case "$OS_TYPE" in
  Linux|Darwin) ;;
  *) echo "ERROR: Unsupported OS: ${OS_TYPE}" >&2; exit 1 ;;
esac

echo "=== voice-mode bootstrap ==="
echo "Platform: ${OS_TYPE}"
echo

# --- Install dependencies ---
echo "--- Dependencies ---"
_ensure_python3 || exit 1
_ensure_piper || echo "⚠ piper unavailable — say will fall back to text output" >&2
_ensure_playback || echo "⚠ playback tool unavailable — say will synthesize but skip audio" >&2
_ensure_recording || echo "⚠ recording tool unavailable — listen file mode may not work" >&2
_ensure_faster_whisper || echo "⚠ faster-whisper unavailable — transcription will not work" >&2
_ensure_numpy || echo "⚠ numpy unavailable — streaming mode may not work" >&2
_ensure_pyaudio || echo "⚠ pyaudio unavailable — streaming mode may not work" >&2
echo

# --- Install scripts ---
echo "--- Scripts ---"
mkdir -p "$INSTALL_DIR"

SCRIPTS=(say listen listen-server _install-deps)
for name in "${SCRIPTS[@]}"; do
  src="$SCRIPT_DIR/$name"
  dst="$INSTALL_DIR/$name"
  [[ -f "$src" ]] || { echo "ERROR: missing $src" >&2; exit 1; }
  cp "$src" "$dst"
  chmod +x "$dst"
  echo "✓ Installed: $dst"
done

if [[ -e "$INSTALL_DIR/duplex" ]]; then
  rm -f "$INSTALL_DIR/duplex"
  echo "✓ Removed deprecated: $INSTALL_DIR/duplex"
fi

CURRENT_SAY="$(command -v say 2>/dev/null || true)"
if [[ -n "$CURRENT_SAY" && "$CURRENT_SAY" != "$INSTALL_DIR/say" ]]; then
  echo "⚠ current 'say' resolves to $CURRENT_SAY"
  echo "  Ensure ${INSTALL_DIR} comes before system paths in PATH."
fi

if [[ ":${PATH}:" != *":${INSTALL_DIR}:"* ]]; then
  echo "Add to PATH: export PATH=\"${INSTALL_DIR}:\$PATH\""
else
  echo "✓ PATH already includes ${INSTALL_DIR}"
fi

echo
echo "Ready: use 'say' and 'listen' separately, or let the agent run duplex mode (say -> listen)."
