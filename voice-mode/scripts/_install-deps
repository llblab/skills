#!/usr/bin/env bash
# Shared dependency manager for voice-mode scripts.
# Source this file: . "$SCRIPT_DIR/_install-deps"

[[ -n "${_INSTALL_DEPS_LOADED:-}" ]] && return 0
_INSTALL_DEPS_LOADED=1

_pip_install() {
  local pkg=$1
  if ! python3 -m pip --version >/dev/null 2>&1; then
    python3 -m ensurepip --upgrade >/dev/null 2>&1 || true
  fi
  python3 -m pip install "$pkg" >/dev/null 2>&1 && return 0
  python3 -m pip install --user "$pkg" >/dev/null 2>&1 && return 0
  python3 -m pip install --user --force-reinstall "$pkg" >/dev/null 2>&1 && return 0
  python3 -m pip install --user --break-system-packages "$pkg" >/dev/null 2>&1 && return 0
  return 1
}

_ensure_cmd() {
  local cmd=$1 apt_pkg=$2 brew_pkg=${3:-$2}
  command -v "$cmd" >/dev/null 2>&1 && return 0
  echo "⚙ $cmd not found — installing $apt_pkg..." >&2
  case "$(uname -s)" in
    Linux)
      if command -v apt-get >/dev/null 2>&1; then
        sudo apt-get install -y "$apt_pkg" >/dev/null 2>&1 && { echo "✓ $apt_pkg installed" >&2; return 0; }
      fi
      echo "✗ Install manually: sudo apt install $apt_pkg" >&2 ;;
    Darwin)
      if command -v brew >/dev/null 2>&1; then
        brew install "$brew_pkg" >/dev/null 2>&1 && { echo "✓ $brew_pkg installed" >&2; return 0; }
      fi
      echo "✗ Install manually: brew install $brew_pkg" >&2 ;;
  esac
  return 1
}

_ensure_pip_pkg() {
  local import_name=$1 pip_name=${2:-$1}
  python3 -c "import $import_name" 2>/dev/null && return 0
  echo "⚙ Installing $pip_name..." >&2
  if _pip_install "$pip_name"; then
    echo "✓ $pip_name installed" >&2
    return 0
  fi
  echo "✗ Failed to install $pip_name. Run: pip install $pip_name" >&2
  return 1
}

_ensure_python3() {
  command -v python3 >/dev/null 2>&1 && return 0
  echo "⚙ python3 not found — attempting install..." >&2
  case "$(uname -s)" in
    Linux)
      if command -v apt-get >/dev/null 2>&1; then
        sudo apt-get install -y python3 python3-pip >/dev/null 2>&1 && { echo "✓ python3 installed" >&2; return 0; }
      fi
      echo "✗ Install: sudo apt install python3 python3-pip" >&2 ;;
    Darwin)
      if command -v brew >/dev/null 2>&1; then
        brew install python3 >/dev/null 2>&1 && { echo "✓ python3 installed" >&2; return 0; }
      fi
      echo "✗ Install: brew install python3" >&2 ;;
  esac
  return 1
}

_ensure_piper() {
  command -v piper >/dev/null 2>&1 && return 0
  echo "⚙ piper not found — installing piper-tts..." >&2
  if ! _pip_install piper-tts; then
    echo "✗ Failed to auto-install piper-tts." >&2
    echo "  pip install piper-tts" >&2
    echo "  Or: https://github.com/rhasspy/piper/releases" >&2
    return 1
  fi
  hash -r 2>/dev/null
  if command -v piper >/dev/null 2>&1; then
    echo "✓ piper-tts installed" >&2
    return 0
  fi
  if [[ -x "$HOME/.local/bin/piper" ]]; then
    export PATH="$HOME/.local/bin:$PATH"
    echo "✓ piper-tts installed (added ~/.local/bin to PATH)" >&2
    return 0
  fi
  echo "✗ piper-tts package installed but 'piper' not found in PATH." >&2
  echo "  Try: export PATH=\"\$HOME/.local/bin:\$PATH\"" >&2
  return 1
}

_ensure_playback() {
  case "$(uname -s)" in
    Darwin)
      command -v afplay >/dev/null 2>&1 && return 0
      echo "⚠ afplay not found (should be built-in on macOS)" >&2
      return 1 ;;
    *)
      command -v aplay >/dev/null 2>&1 && return 0
      _ensure_cmd aplay alsa-utils ;;
  esac
}

_ensure_recording() {
  case "$(uname -s)" in
    Darwin)
      command -v rec >/dev/null 2>&1 && return 0
      _ensure_cmd rec sox sox ;;
    *)
      command -v arecord >/dev/null 2>&1 && return 0
      _ensure_cmd arecord alsa-utils ;;
  esac
}

_ensure_pyaudio() {
  python3 -c "import pyaudio" 2>/dev/null && return 0
  # pyaudio needs native portaudio headers to compile
  case "$(uname -s)" in
    Linux)
      if command -v apt-get >/dev/null 2>&1; then
        echo "⚙ Installing portaudio19-dev (needed for pyaudio)..." >&2
        sudo apt-get install -y portaudio19-dev >/dev/null 2>&1 || true
      fi ;;
    Darwin)
      if command -v brew >/dev/null 2>&1; then
        echo "⚙ Installing portaudio (needed for pyaudio)..." >&2
        brew install portaudio >/dev/null 2>&1 || true
      fi ;;
  esac
  _ensure_pip_pkg pyaudio pyaudio
}

_ensure_numpy() {
  _ensure_pip_pkg numpy numpy
}

_ensure_faster_whisper() {
  _ensure_pip_pkg faster_whisper faster-whisper
}
