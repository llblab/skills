#!/usr/bin/env bash
# Self-test for voice-mode super-skill
# Validates: structure, atomic voice scripts, bootstrap, and duplex agent protocol docs
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SKILL_DIR="$(dirname "$SCRIPT_DIR")"

SAY_SCRIPT="$SKILL_DIR/scripts/say"
LISTEN_SCRIPT="$SKILL_DIR/scripts/listen"
LISTEN_SERVER="$SKILL_DIR/scripts/listen-server"
BOOTSTRAP="$SKILL_DIR/scripts/_bootstrap"
DUPLEX_DOC="$SKILL_DIR/docs/duplex-mode.md"
LEGACY_DUPLEX_SCRIPT="$SKILL_DIR/scripts/duplex"
LEGACY_DUPLEX_DOC="$SKILL_DIR/docs/duplex-script.md"

PASS=0
FAIL=0
TOTAL=0

record_result() {
  local desc=$1
  local ok=$2
  TOTAL=$((TOTAL + 1))
  if [[ "$ok" == "1" ]]; then
    echo "  ✓ $desc"
    PASS=$((PASS + 1))
  else
    echo "  ✗ $desc"
    FAIL=$((FAIL + 1))
  fi
}

assert_file_exists() {
  local desc=$1
  local path=$2
  if [[ -f "$path" ]]; then
    record_result "$desc" 1
  else
    record_result "$desc" 0
  fi
}

assert_file_absent() {
  local desc=$1
  local path=$2
  if [[ ! -e "$path" ]]; then
    record_result "$desc" 1
  else
    record_result "$desc" 0
  fi
}

assert_executable() {
  local desc=$1
  local path=$2
  if [[ -x "$path" ]]; then
    record_result "$desc" 1
  else
    record_result "$desc" 0
  fi
}

assert_contains() {
  local desc=$1
  local needle=$2
  local path=$3
  if grep -Fq -- "$needle" "$path"; then
    record_result "$desc" 1
  else
    record_result "$desc" 0
  fi
}

assert_not_contains() {
  local desc=$1
  local needle=$2
  local path=$3
  if grep -Fq -- "$needle" "$path"; then
    record_result "$desc" 0
  else
    record_result "$desc" 1
  fi
}

echo ">>> SELF-TEST: voice-mode super-skill <<<"
echo

echo "File Structure:"
assert_file_exists "SKILL.md exists" "$SKILL_DIR/SKILL.md"
assert_file_exists "AGENTS.md exists" "$SKILL_DIR/AGENTS.md"
assert_file_exists "README.md exists" "$SKILL_DIR/README.md"
assert_file_exists "scripts/say exists" "$SAY_SCRIPT"
assert_file_exists "scripts/listen exists" "$LISTEN_SCRIPT"
assert_file_exists "scripts/listen-server exists" "$LISTEN_SERVER"
assert_file_exists "scripts/_bootstrap exists" "$BOOTSTRAP"
assert_executable "say executable" "$SAY_SCRIPT"
assert_executable "listen executable" "$LISTEN_SCRIPT"
assert_executable "listen-server executable" "$LISTEN_SERVER"
assert_executable "_bootstrap executable" "$BOOTSTRAP"
assert_file_exists "docs/README.md exists" "$SKILL_DIR/docs/README.md"
assert_file_exists "docs/tts-script.md exists" "$SKILL_DIR/docs/tts-script.md"
assert_file_exists "docs/stt-script.md exists" "$SKILL_DIR/docs/stt-script.md"
assert_file_exists "docs/duplex-mode.md exists" "$DUPLEX_DOC"
assert_file_absent "scripts/duplex removed" "$LEGACY_DUPLEX_SCRIPT"
assert_file_absent "docs/duplex-script.md removed" "$LEGACY_DUPLEX_DOC"
echo

echo "Say Script Analysis:"
assert_contains "Has set -euo pipefail" "set -euo pipefail" "$SAY_SCRIPT"
assert_contains "Has MODELS array" "declare -A MODELS" "$SAY_SCRIPT"
assert_contains "Uses mktemp" "mktemp" "$SAY_SCRIPT"
assert_contains "Has trap cleanup" "trap 'rm -f \"\$OUT_FILE\"' EXIT" "$SAY_SCRIPT"
assert_contains "Uses curl -fSL" "curl -fSL" "$SAY_SCRIPT"
assert_contains "Normalizes underscore locales" "CURRENT_LANG=\"\${CURRENT_LANG%%_*}\"" "$SAY_SCRIPT"
assert_contains "Normalizes dash locales" "CURRENT_LANG=\"\${CURRENT_LANG%%-*}\"" "$SAY_SCRIPT"
assert_contains "Checks piper presence" "command -v piper" "$SAY_SCRIPT"
assert_contains "Defaults to ~/.piper-voices" ".piper-voices" "$SAY_SCRIPT"
assert_contains "Graceful piper fallback" "printing text instead of speaking" "$SAY_SCRIPT"
echo

echo "Listen Script Analysis:"
assert_contains "Has set -euo pipefail" "set -euo pipefail" "$LISTEN_SCRIPT"
assert_contains "Supports --interval flag" "--interval" "$LISTEN_SCRIPT"
assert_contains "Supports --silence flag" "--silence" "$LISTEN_SCRIPT"
assert_contains "Uses streaming socket path" "listen-server.sock" "$LISTEN_SCRIPT"
assert_contains "Streaming protocol header STRM" "sock.sendall(b\"STRM\")" "$LISTEN_SCRIPT"
assert_contains "Streaming protocol end marker END" "sock.sendall(b\"END\\n\")" "$LISTEN_SCRIPT"
assert_contains "Has pyaudio import path" "import pyaudio" "$LISTEN_SCRIPT"
assert_contains "Auto-starts listen-server" "Starting listen-server" "$LISTEN_SCRIPT"
assert_contains "Uses ~/.pi_voice_lang" "LANG_FILE=\"\${HOME}/.pi_voice_lang\"" "$LISTEN_SCRIPT"
echo

echo "Listen-Server Analysis:"
assert_contains "Has STREAM_HEADER constant" "STREAM_HEADER = b\"STRM\"" "$LISTEN_SERVER"
assert_contains "Has STREAM_END constant" "STREAM_END = b\"END\\n\"" "$LISTEN_SERVER"
assert_contains "Uses transcribe lock" "transcribe_lock" "$LISTEN_SERVER"
assert_contains "Has stream handler" "_handle_stream" "$LISTEN_SERVER"
assert_contains "Has file handler" "_handle_file" "$LISTEN_SERVER"
assert_contains "Uses faster-whisper model" "from faster_whisper import WhisperModel" "$LISTEN_SERVER"
assert_contains "Has dependency auto-installer" "def _ensure_dep" "$LISTEN_SERVER"
echo

echo "Bootstrap Analysis:"
assert_contains "Bootstrap has set -euo pipefail" "set -euo pipefail" "$BOOTSTRAP"
assert_contains "Bootstrap sources _install-deps" "_install-deps" "$BOOTSTRAP"
assert_contains "Bootstrap installs atomic scripts" "SCRIPTS=(say listen listen-server _install-deps)" "$BOOTSTRAP"
assert_contains "Bootstrap prunes deprecated duplex" "rm -f \"\$INSTALL_DIR/duplex\"" "$BOOTSTRAP"
assert_contains "Bootstrap message mentions agent duplex mode" "let the agent run duplex mode" "$BOOTSTRAP"
assert_not_contains "Bootstrap no longer installs duplex" "SCRIPTS=(say listen listen-server duplex _install-deps)" "$BOOTSTRAP"
echo

echo "CLI Smoke Checks:"
set +e
EMPTY_OUT=$(echo "" | bash "$SAY_SCRIPT" 2>&1)
EMPTY_EXIT=$?
LISTEN_HELP_OUT=$(bash "$LISTEN_SCRIPT" -h 2>&1)
LISTEN_HELP_EXIT=$?
set -e

if [[ $EMPTY_EXIT -eq 0 ]]; then
  record_result "say handles empty input (exit 0)" 1
else
  record_result "say handles empty input (exit 0)" 0
fi
if grep -Fq "Downloading voice model" <<< "$EMPTY_OUT"; then
  record_result "say empty input does not download" 0
else
  record_result "say empty input does not download" 1
fi
if [[ $LISTEN_HELP_EXIT -eq 0 ]]; then
  record_result "listen -h exits 0" 1
else
  record_result "listen -h exits 0" 0
fi
if grep -Fq "Usage: listen" <<< "$LISTEN_HELP_OUT"; then
  record_result "listen -h shows usage" 1
else
  record_result "listen -h shows usage" 0
fi
echo

echo "Duplex Protocol Docs:"
assert_contains "README mentions offline-first" "Offline-first voice I/O skill for agents:" "$SKILL_DIR/README.md"
assert_contains "README describes agent-level duplex" "agent-level orchestration" "$SKILL_DIR/README.md"
assert_contains "SKILL metadata mentions offline-first" "Offline-first voice I/O super-skill" "$SKILL_DIR/SKILL.md"
assert_contains "SKILL describes local STT/TTS" "This is an offline-first skill" "$SKILL_DIR/SKILL.md"
assert_contains "Docs say no dedicated duplex shell script" 'There is no dedicated `duplex` shell script in this skill.' "$DUPLEX_DOC"
assert_contains "Docs mention stop phrase" "stop listening" "$DUPLEX_DOC"
assert_contains "Docs mention duplex stop phrase" "выключи дуплекс" "$DUPLEX_DOC"
assert_contains "Docs use no hard timeout pattern" "listen -l <lang> -d 0 -s 1" "$DUPLEX_DOC"
assert_contains "Docs forbid split-brain duplex UX" "split-brain UX" "$DUPLEX_DOC"
assert_contains "Docs say continuous duplex is agent behavior" "Continuous duplex is an agent behavior, not a shell helper." "$DUPLEX_DOC"
assert_contains "SKILL says duplex is not standalone shell script" "Duplex mode is not a standalone shell script in this skill." "$SKILL_DIR/SKILL.md"
assert_contains "SKILL documents stop phrases" "stop listening" "$SKILL_DIR/SKILL.md"
assert_contains "SKILL documents duplex stop phrase" "выключи дуплекс" "$SKILL_DIR/SKILL.md"
assert_contains "SKILL documents no hard timeout pattern" "listen -d 0 -s 1" "$SKILL_DIR/SKILL.md"
assert_contains "SKILL requires full spoken response" 'Speak the full response via `say`' "$SKILL_DIR/SKILL.md"
echo

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Results: $PASS/$TOTAL passed, $FAIL failed"
if [[ $FAIL -eq 0 ]]; then
  echo "✅ All tests passed"
  exit 0
else
  echo "❌ $FAIL test(s) failed"
  exit 1
fi
